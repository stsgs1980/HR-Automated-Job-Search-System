{
  "manifest_version": 3,
  "name": "HH Auto-Respond",
  "description": "Автоматизация откликов на hh.ru — встроенная панель прямо на странице поиска вакансий",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "cookies",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://hh.ru/*",
    "https://*.hh.ru/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://hh.ru/search/vacancy*",
        "https://hh.ru/vacancy/*",
        "https://hh.ru/applicant/negotiations*",
        "https://hh.ru/applicant/resumes*"
      ],
      "js": ["lib/selectors.js", "lib/anti-hallucination.js", "lib/timing.js", "lib/storage.js", "lib/rate-limiter.js", "lib/matching.js", "content/panel.js", "content/parser.js", "content/auto-respond.js", "content/main.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/panel.css"],
      "matches": ["https://hh.ru/*"]
    }
  ]
}
